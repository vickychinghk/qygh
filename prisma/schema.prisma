generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  displayName  String
  passwordHash String
  createdAt    DateTime   @default(now())
  comments     Comment[]
  reactions    Reaction[]
  selections   Selection[]
}

model Submission {
  id              String            @id @default(cuid())
  feishuRecordId  String?           @unique
  serialNumber    String?
  school          String
  submitterQuote  String
  consentGranted  Boolean           @default(false)
  submittedAt     DateTime
  status          String            @default("PENDING")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  images          SubmissionImage[]
  issueItems      IssueItem[]
  comments        Comment[]
  reactions       Reaction[]
  selections      Selection[]
}

model SubmissionImage {
  id               String     @id @default(cuid())
  submissionId     String
  remoteUrl        String?
  localPath        String
  originalPath     String?
  assetKind        String     @default("IMAGE")
  width            Int?
  height           Int?
  bytes            Int?
  originalBytes    Int?
  processedBytes   Int?
  originalFormat   String?
  processedFormat  String?
  mimeType         String?
  processingStatus String     @default("READY")
  processingError  String?
  enabled          Boolean    @default(true)
  sortOrder        Int        @default(0)
  updatedAt        DateTime   @updatedAt
  submission       Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Issue {
  id        String      @id @default(cuid())
  title     String
  monthKey  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     IssueItem[]
}

model IssueItem {
  id           String     @id @default(cuid())
  issueId      String
  submissionId String
  sortOrder    Int
  confirmed    Boolean    @default(false)
  issue        Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([issueId, submissionId])
}

model Comment {
  id           String     @id @default(cuid())
  submissionId String
  authorId     String?
  body         String
  source       String     @default("EDITOR")
  selected     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author       User?      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions    Reaction[]
  selections   Selection[]
}

model Reaction {
  id           String         @id @default(cuid())
  userId       String
  kind         String
  targetType   String
  submissionId String?
  commentId    String?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission   Submission?    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  comment      Comment?       @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, targetType, submissionId, commentId])
}

model Selection {
  id           String          @id @default(cuid())
  userId       String
  targetType   String
  submissionId String?
  commentId    String?
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission   Submission?     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  comment      Comment?        @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, submissionId, commentId])
}

model SyncJob {
  id                 String    @id @default(cuid())
  status             String    @default("RUNNING")
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  created            Int       @default(0)
  updated            Int       @default(0)
  failed             Int       @default(0)
  skipped            Int       @default(0)
  scanned            Int       @default(0)
  imageAttempted     Int       @default(0)
  imageDownloaded    Int       @default(0)
  imageExisting      Int       @default(0)
  imageFailed        Int       @default(0)
  imageSkipped       Int       @default(0)
  cursorSubmittedAt  DateTime?
  cursorSerialNumber String?
  cursorRecordId     String?
  complete           Boolean   @default(false)
  details            String?
  error              String?
}
